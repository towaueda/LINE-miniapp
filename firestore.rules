rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // messages コレクション: クライアントSDK の onSnapshot 用に読み取りのみ許可
    // 書き込みは全て Admin SDK (サーバー側) 経由のため拒否
    match /messages/{messageId} {
      allow read: if true;
      allow write: if false;
    }

    // その他のコレクションは全てサーバー側 (Admin SDK) からのみアクセス
    // クライアントからの直接アクセスは不要なため全て拒否
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
